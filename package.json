{
  "name": "strain",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "web": "pnpm --filter @strain/web",
    "mobile": "pnpm --filter @strain/mobile",
    "dev:web": "pnpm --filter @strain/web dev",
    "dev:mobile": "pnpm --filter @strain/mobile start",
    "build:web": "pnpm --filter @strain/web build",
    "lint:web": "pnpm --filter @strain/web lint",
    "lint": "expo lint"
  },
  "engines": {
    "node": ">=20"
  }
}
